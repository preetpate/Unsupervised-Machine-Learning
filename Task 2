import math

def assign_clusters(points, centroids, metric='euclidean'):
    assignments = []
    
    for p in points:
        min_dist = float('inf')
        best_cluster = -1
        
        for c_idx, c in enumerate(centroids):
            if metric.lower() == 'euclidean':
                # Straight-line distance
                dist = math.sqrt(sum((pi - ci) ** 2 for pi, ci in zip(p, c)))
            elif metric.lower() == 'manhattan':
                # Grid-like distance
                dist = sum(abs(pi - ci) for pi, ci in zip(p, c))
            else:
                raise ValueError("Metric must be either 'euclidean' or 'manhattan'")
            
            if dist < min_dist:
                min_dist = dist
                best_cluster = c_idx
                
        assignments.append(best_cluster)
        
    return assignments

