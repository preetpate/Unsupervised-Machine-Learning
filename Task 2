def update_centroids(points, assignments, k):
    # Initialize empty coordinate trackers and counters for k clusters
    dimensions = len(points[0])
    new_centroids = [[0.0] * dimensions for _ in range(k)]
    counts = [0] * k
    
    # Sum up all matching coordinates
    for p, cluster_idx in zip(points, assignments):
        counts[cluster_idx] += 1
        for dim in range(dimensions):
            new_centroids[cluster_idx][dim] += p[dim]
            
    # Compute the true mathematical mean
    for cluster_idx in range(k):
        if counts[cluster_idx] > 0:
            for dim in range(dimensions):
                new_centroids[cluster_idx][dim] /= counts[cluster_idx]
        else:
            # Fallback handle if a cluster ends up completely empty
            new_centroids[cluster_idx] = [0.0] * dimensions
            
    return new_centroids

