import numpy as np
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans

# Generating mock restaurant dataset: [Avg Price per Person ($), Rating (1-5)]
np.random.seed(24)
group_1 = np.random.normal(loc=[15, 3.2], scale=[3, 0.3], size=(30, 2))  # Cheap, average ratings
group_2 = np.random.normal(loc=[45, 4.5], scale=[5, 0.2], size=(30, 2))  # Mid-high tier, excellent reviews
group_3 = np.random.normal(loc=[110, 4.2], scale=[10, 0.4], size=(30, 2)) # High luxury, good reviews
X = np.vstack([group_1, group_2, group_3])

wcss = []
k_range = range(1, 7)

for k in k_range:
    kmeans = KMeans(n_clusters=k, init='k-means++', random_state=42, n_init=10)
    kmeans.fit(X)
    wcss.append(kmeans.inertia_)

# Plotting the Elbow Curve
plt.figure(figsize=(8, 5))
plt.plot(k_range, wcss, marker='o', linestyle='--', color='b')
plt.title('Elbow Method for Optimal Restaurant Segmentation Clusters')
plt.xlabel('Number of Clusters (k)')
plt.ylabel('WCSS (Inertia)')
plt.xticks(k_range)
plt.grid(True)
plt.show()

